# Development Dockerfile for Nuxt services
# Runs in dev mode with hot reload, error overlay, and source maps

FROM node:22-alpine

# API_DEPS - space separated list of API dependency directories (for local development)
# e.g. "ecommerce-catalog-service-api ecommerce-image-service-api"
ARG API_DEPS=""
ARG SERVICE_DIR

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy package and config files needed before install
COPY ${SERVICE_DIR}/package.json ${SERVICE_DIR}/pnpm-lock.yaml ${SERVICE_DIR}/pnpm-workspace.yaml ${SERVICE_DIR}/.npmrc ./
COPY ${SERVICE_DIR}/nuxt.config.ts ./

# Install ALL dependencies (including devDependencies) from registry
RUN --mount=type=secret,id=NODE_AUTH_TOKEN \
    NODE_AUTH_TOKEN=$(cat /run/secrets/NODE_AUTH_TOKEN) pnpm install

# Copy local API dependencies and link them (overrides registry versions)
COPY . /tmp/context/
RUN set -e && \
    for api_dep in ${API_DEPS}; do \
        if [ -d "/tmp/context/${api_dep}/gen/typescript" ]; then \
            echo "Linking local API dependency: ${api_dep}"; \
            mkdir -p "/app/${api_dep}/gen/typescript"; \
            cp -r "/tmp/context/${api_dep}/gen/typescript/." "/app/${api_dep}/gen/typescript/"; \
            cd "/app/${api_dep}/gen/typescript" && npm install && npm run build && cd /app; \
            pnpm link "/app/${api_dep}/gen/typescript"; \
        else \
            echo "WARNING: API dependency not found: ${api_dep}/gen/typescript (skipping)"; \
        fi; \
    done && \
    rm -rf /tmp/context

# Copy application code
COPY ${SERVICE_DIR}/. .

ENV NODE_ENV=development
ENV NUXT_TELEMETRY_DISABLED=1
# Skip SSL verification in dev to avoid issues with corporate proxies / self-signed certs
ENV NODE_TLS_REJECT_UNAUTHORIZED=0

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Run in development mode with hot reload
CMD ["pnpm", "dev"]
