# Development Dockerfile for Nuxt services
# Runs in dev mode with hot reload, error overlay, and source maps

FROM node:22-alpine

# API_DEPS - space separated list of API dependency directories (for local development)
# e.g. "ecommerce-catalog-service-api ecommerce-image-service-api"
ARG API_DEPS=""
ARG SERVICE_DIR

WORKDIR /app

RUN corepack enable

# Copy package and config files needed before install
COPY ${SERVICE_DIR}/package.json ${SERVICE_DIR}/pnpm-lock.yaml ${SERVICE_DIR}/pnpm-workspace.yaml ${SERVICE_DIR}/.npmrc ./
COPY ${SERVICE_DIR}/nuxt.config.ts ./

# Install pnpm (version from package.json packageManager field, cached with package.json layer)
RUN corepack install

# Copy local API dependencies and rewrite pnpm-workspace.yaml overrides to absolute paths.
# If dist/ is missing (fresh clone), build it in place.
COPY . /tmp/context/
RUN set -e && \
    for api_dep in ${API_DEPS}; do \
        if [ -d "/tmp/context/${api_dep}/gen/typescript" ]; then \
            mkdir -p "/app/${api_dep}/gen/typescript"; \
            cp -r "/tmp/context/${api_dep}/gen/typescript/." "/app/${api_dep}/gen/typescript/"; \
            if [ ! -d "/app/${api_dep}/gen/typescript/dist" ]; then \
                cd "/app/${api_dep}/gen/typescript" && npm install && cd /app; \
            fi; \
            sed -i "s|link:\.\./${api_dep}/gen/typescript|link:/app/${api_dep}/gen/typescript|g" /app/pnpm-workspace.yaml; \
        else \
            echo "WARNING: ${api_dep}/gen/typescript not found (skipping)"; \
        fi; \
    done && \
    rm -rf /tmp/context

# Install dependencies — @sokol111/* packages resolved locally via link: protocol
RUN pnpm install --no-frozen-lockfile

# Copy application code
COPY ${SERVICE_DIR}/. .

ENV NODE_ENV=development
ENV NUXT_TELEMETRY_DISABLED=1
# Skip SSL verification in dev to avoid issues with corporate proxies / self-signed certs
ENV NODE_TLS_REJECT_UNAUTHORIZED=0

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Run in development mode with hot reload
CMD ["pnpm", "dev"]
