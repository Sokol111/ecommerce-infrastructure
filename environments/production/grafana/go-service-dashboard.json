{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP — RED Metrics",
      "type": "row"
    },
    {
      "title": "RPS (Requests Per Second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=~\"$job\"}[$__rate_interval])) by (job)",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=~\"$job\", http_response_status_code=~\"5..\"}[$__rate_interval])) by (job)\n/\nsum(rate(http_server_request_duration_seconds_count{job=~\"$job\"}[$__rate_interval])) by (job)",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(http_server_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "MongoDB",
      "type": "row"
    },
    {
      "title": "MongoDB Query Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(db_client_operation_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_client_operation_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(db_client_operation_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "MongoDB Operations / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(db_client_operation_duration_seconds_count{job=~\"$job\"}[$__rate_interval])) by (db_operation_name, instance)",
          "legendFormat": "{{ db_operation_name }} — {{ instance }}"
        }
      ]
    },
    {
      "title": "MongoDB Latency by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_client_operation_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])) by (le, db_operation_name))",
          "legendFormat": "p95 {{ db_operation_name }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Go Runtime",
      "type": "row"
    },
    {
      "title": "Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_goroutine_count{job=~\"$job\"}",
          "legendFormat": "{{ job }} — {{ instance }}"
        }
      ]
    },
    {
      "title": "Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never", "stacking": { "mode": "normal" } },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_memory_used_bytes{job=~\"$job\"}",
          "legendFormat": "{{ instance }} — {{ go_memory_type }}"
        }
      ]
    },
    {
      "title": "Memory Allocation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "Bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(go_memory_allocated_bytes_total{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "{{ job }} — {{ instance }}"
        }
      ]
    },
    {
      "title": "GC Goal vs Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "go_memory_gc_goal_bytes{job=~\"$job\"}",
          "legendFormat": "GC goal — {{ instance }}"
        },
        {
          "expr": "sum(go_memory_used_bytes{job=~\"$job\"}) by (instance)",
          "legendFormat": "Used — {{ instance }}"
        }
      ]
    },
    {
      "title": "GC Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(go_gc_collections_total{job=~\"$job\"}[$__rate_interval])",
          "legendFormat": "{{ job }} — {{ instance }}"
        }
      ]
    },
    {
      "title": "Service Info",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "id": 12,
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "options": {
        "showHeader": true,
        "frameIndex": 0
      },
      "transformations": [
        {
          "id": "reduce",
          "options": { "reducers": ["lastNotNull"] }
        }
      ],
      "targets": [
        {
          "expr": "go_processor_limit{job=~\"$job\"}",
          "legendFormat": "GOMAXPROCS: {{ job }}",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["go", "otel", "ecommerce"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(go_goroutine_count, job)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "job",
        "query": "label_values(go_goroutine_count, job)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "E-Commerce — Go Services",
  "uid": "ecommerce-go-services",
  "version": 1
}
