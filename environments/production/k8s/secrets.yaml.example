# =============================================================================
# Kubernetes Secrets Template
# =============================================================================
# Copy this file to secrets.yaml, fill in real values, and apply:
#   kubectl apply -f secrets.yaml
# NEVER commit secrets.yaml to git!
#
# Generate base64 values: echo -n 'value' | base64

# --- prod namespace ---

---
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-credentials
  namespace: prod
type: Opaque
data:
  connection-string: Q0hBTkdFX01F   # CHANGE_ME

---
apiVersion: v1
kind: Secret
metadata:
  name: auth-keys
  namespace: prod
type: Opaque
data:
  public-key: Q0hBTkdFX01F      # CHANGE_ME (generate with auth-service keygen)
  private-key: Q0hBTkdFX01F     # CHANGE_ME (generate with auth-service keygen)

---
apiVersion: v1
kind: Secret
metadata:
  name: admin-credentials
  namespace: prod
type: Opaque
data:
  email: YWRtaW5AZXhhbXBsZS5jb20=    # admin@example.com
  password: Q0hBTkdFX01F              # CHANGE_ME

---
apiVersion: v1
kind: Secret
metadata:
  name: r2-credentials
  namespace: prod
type: Opaque
data:
  access-key-id: Q0hBTkdFX01F    # CHANGE_ME (Cloudflare R2 Access Key)
  secret-key: Q0hBTkdFX01F       # CHANGE_ME (Cloudflare R2 Secret Key)

---
apiVersion: v1
kind: Secret
metadata:
  name: imgproxy-keys
  namespace: prod
type: Opaque
data:
  key: Q0hBTkdFX01F       # CHANGE_ME (openssl rand -hex 32 | base64)
  salt: Q0hBTkdFX01F      # CHANGE_ME (openssl rand -hex 32 | base64)

---
apiVersion: v1
kind: Secret
metadata:
  name: image-service-secrets
  namespace: prod
type: Opaque
data:
  jwt-secret: Q0hBTkdFX01F  # CHANGE_ME (openssl rand -hex 32 | base64)

# --- observability namespace ---

---
apiVersion: v1
kind: Secret
metadata:
  name: grafana-cloud
  namespace: observability
type: Opaque
data:
  prometheus-url: Q0hBTkdFX01F     # CHANGE_ME
  prometheus-user: Q0hBTkdFX01F    # CHANGE_ME
  loki-url: Q0hBTkdFX01F           # CHANGE_ME
  loki-user: Q0hBTkdFX01F          # CHANGE_ME
  tempo-url: Q0hBTkdFX01F          # CHANGE_ME
  tempo-user: Q0hBTkdFX01F         # CHANGE_ME
  api-key: Q0hBTkdFX01F            # CHANGE_ME

# --- kube-system namespace (Cloudflare Origin Certificate) ---

---
apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-origin-tls
  namespace: kube-system
type: kubernetes.io/tls
data:
  tls.crt: Q0hBTkdFX01F   # CHANGE_ME: base64-encode the Origin Certificate PEM
  tls.key: Q0hBTkdFX01F   # CHANGE_ME: base64-encode the Private Key PEM
  # Generate with:
  #   cat origin-cert.pem | base64 -w0
  #   cat origin-key.pem | base64 -w0
